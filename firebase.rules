rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;

      allow update: if request.auth != null
        && (
          // Existing members can update the room.
          request.auth.uid in resource.data.memberIds ||
          // Self-join: a non-member may only add themselves to memberIds.
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(["memberIds", "updatedAt"]) &&
            request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
            request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
            request.resource.data.memberIds.hasAny([request.auth.uid]) &&
            (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp)
          )
        );

      allow create: if request.auth != null;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds;
      }
    }

    match /joinCodes/{code} {
      allow read, create: if request.auth != null;
    }

    // Users — only the user themselves
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
