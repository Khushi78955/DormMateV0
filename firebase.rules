rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.memberIds ||
        (
          request.query.size() == 1 &&
          request.query.where[0].fieldPath == "joinCode" &&
          request.query.where[0].op == "=="
        )
      );

      allow write: if request.auth != null
        && (
          request.auth.uid in resource.data.memberIds ||
          (
            request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
            request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
            request.resource.data.memberIds.has(request.auth.uid)
          )
        );

      allow create: if request.auth != null;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds;
      }
    }

    match /joinCodes/{code} {
      allow read, create: if request.auth != null;
    }

    // Users — only the user themselves
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
